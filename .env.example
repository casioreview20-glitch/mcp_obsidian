# Copy this file to .env for local development. Never commit .env.
# Use forward slashes on Windows, or set values in your shell instead.

# Required when running outside an Obsidian vault directory.
AI_BRAIN_VAULT=C:/path/to/Your Obsidian Vault

# Optional. Default: <AI_BRAIN_VAULT>/.ai-brain/chroma
# AI_BRAIN_DB=C:/path/to/Your Obsidian Vault/.ai-brain/chroma

# REST is intentionally loopback-only.
AI_BRAIN_HOST=127.0.0.1
AI_BRAIN_PORT=8765

# Optional. If set, vault-data REST endpoints require X-Local-Token.
# Generate and store a private value locally; never commit it.
# AI_BRAIN_TOKEN=
